# ============================================
# SERVER CONFIG - EXAMPLE FILE
# ============================================
# This file is a TEMPLATE — it documents every env var the server
# needs, with placeholder values. It IS committed to git so a new
# dev can see what's required.
#
# Copy it to `.env` and fill in your real values:
#   cp .env.example .env       (Mac/Linux)
#   copy .env.example .env     (Windows)
#
# Real secrets (the actual `.env` file) are gitignored — never
# commit them.
# ============================================

# Which port our API runs on
PORT=5000

# development | production
NODE_ENV=development

# ============================================
# DATABASE
# ============================================
# Atlas connection string from https://cloud.mongodb.com/
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=

# ============================================
# AUTHENTICATION (JWT)
# ============================================
# Generate a long random string for production:
#   openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ============================================
# EMAIL (SMTP)
# ============================================
# true  = emails are NOT sent; OTPs print to the server console
# false = emails are sent via the SMTP settings below
MAIL_DRY_RUN=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=
MAIL_PASS=
MAIL_FROM=FoodApp <noreply@example.com>

# ============================================
# FRONTEND
# ============================================
# Where the React app runs — used for CORS and OAuth redirects.
# Comma-separate multiple if you have several (dev + prod).
CLIENT_URL=http://localhost:5173

# ============================================
# STRIPE
# ============================================
# Get TEST keys at https://dashboard.stripe.com/test/apikeys
# Test mode is free — use fake card 4242 4242 4242 4242
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ============================================
# PAYPAL
# ============================================
# Get sandbox creds at https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# "sandbox" for testing, "live" for production
PAYPAL_MODE=sandbox

# ============================================
# SAFEPAY (hosted checkout)
# ============================================
# Get sandbox keys at https://developer.safepay.pk/ (sign in →
# Developer → API). The dashboard shows two keys:
#   - Public key  (starts with "sec_") — used in the FRONTEND if
#                 you embed the Safepay.js widget. Not used for
#                 the hosted-page redirect (which is what we do).
#   - Secret key  (long hex string) — used in the BACKEND as the
#                 Bearer token for all Safepay API calls.
#
# BOTH are REQUIRED for /api/payments/safepay/checkout to work.
# Without them, the endpoint returns a 500 with a clear
# "Safepay is not configured" message.
#
# SF_MODE picks the right API base URL:
#   - sandbox  → https://api.sandbox.safepay.pk  (test mode)
#   - live     → https://api.safepay.pk           (production, real money)
# Defaults to "sandbox" if unset (safe default).
#
# SF_BASE_URL is the public origin of your FRONTEND — used to
# build the success/failure redirect URLs that Safepay sends the
# customer to. Set this to your deployed frontend URL in
# production (e.g. https://flavourcourt.vercel.app).
SF_MODE=sandbox
SF_PUBLIC_KEY=
SF_SECRET_KEY=
SF_BASE_URL=http://localhost:5173
