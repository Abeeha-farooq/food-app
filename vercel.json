{
"installCommand": "npm --prefix client install --include=dev && npm --prefix server install --omit=dev && npm --prefix api install --omit=dev",

  "buildCommand": "node scripts/copy-server.js && cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/handler"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/handler.js": {
      "maxDuration": 10,
      "memory": 1024
    }
  }
}
